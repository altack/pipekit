#!/usr/bin/env bash
# pipekit-agent — the contract implementation. See docs/contract.md.
#
# Resolves which agent driver to run (claude-code | codex | copilot | …),
# materializes inputs.json, hands prompt + workspace to the driver, validates
# result.json, and computes the verdict.
#
# Inputs (env):
#   PIPEKIT_PROMPT       @pipekit/<name> or path to a .md system prompt   [required]
#   PIPEKIT_INPUTS       JSON blob (default "{}"); written to inputs.json
#   PIPEKIT_PASS_WHEN    optional jq expression evaluated against result.json
#   PIPEKIT_WORKSPACE    scratch dir (default /work)
#   PIPEKIT_AGENT        explicit driver name (claude-code | codex | copilot | …)
#                        if unset, walk PIPEKIT_PREFERRED and pick the first available
#   PIPEKIT_PREFERRED    comma-separated ordered fallback (default "claude-code")
#   PIPEKIT_MODEL        agent-specific model id (driver decides default)
#   PIPEKIT_MAX_TURNS    safety cap (default 200)
#   <agent creds>        whichever credentials the chosen driver needs
#                          claude-code → ANTHROPIC_API_KEY
#                          codex       → OPENAI_API_KEY
#                          copilot     → GH_TOKEN / gh auth
#
# Outputs (under $PIPEKIT_WORKSPACE):
#   inputs.json     mirror of $PIPEKIT_INPUTS
#   result.json     the verdict (status, summary, findings, outputs)
#   agent.jsonl     raw agent output (driver-specific format)
#   artifacts/      anything the prompt produced
#
# Exit codes:
#   0  pass        (status="pass" or pass_when truthy)
#   1  agent fail  (status="fail" or pass_when falsy)
#   2  infra fail  (no result.json, prompt missing, no driver available, etc.)

set -euo pipefail

log()  { echo "[pipekit] $*" >&2; }
fail() { log "ERROR: $*"; exit 2; }

: "${PIPEKIT_PROMPT:?required: built-in @pipekit/<name> or path to a prompt file}"

WORKSPACE="${PIPEKIT_WORKSPACE:-/work}"
mkdir -p "$WORKSPACE/artifacts"

# ─── Resolve prompt ────────────────────────────────────────────────────────
case "$PIPEKIT_PROMPT" in
  @pipekit/*) PROMPT_PATH="/pipekit/prompts/${PIPEKIT_PROMPT#@pipekit/}.md" ;;
  *)          PROMPT_PATH="$PIPEKIT_PROMPT" ;;
esac
[[ -r "$PROMPT_PATH" ]] || fail "prompt not found or unreadable: $PROMPT_PATH"
log "prompt: $PROMPT_PATH"

# ─── Materialize inputs.json ───────────────────────────────────────────────
INPUTS="${PIPEKIT_INPUTS-}"
[[ -z "$INPUTS" ]] && INPUTS='{}'
printf '%s' "$INPUTS" > "$WORKSPACE/inputs.json"
jq empty "$WORKSPACE/inputs.json" 2>/dev/null \
  || fail "PIPEKIT_INPUTS is not valid JSON"
log "workspace: $WORKSPACE"

# ─── Resolve agent driver ──────────────────────────────────────────────────
DRIVERS_DIR="/pipekit/drivers"
PREFERRED="${PIPEKIT_PREFERRED:-claude-code}"

agent_check() {
  # $1 = driver name. Returns 0 if available.
  local name="$1"
  local check_sh="$DRIVERS_DIR/$name/check.sh"
  [[ -x "$check_sh" ]] || return 1
  "$check_sh" >/dev/null 2>&1
}

PICK=""
if [[ -n "${PIPEKIT_AGENT:-}" ]]; then
  log "agent (explicit): $PIPEKIT_AGENT"
  if [[ ! -d "$DRIVERS_DIR/$PIPEKIT_AGENT" ]]; then
    fail "unknown agent: '$PIPEKIT_AGENT' (no driver at $DRIVERS_DIR/$PIPEKIT_AGENT)"
  fi
  if ! agent_check "$PIPEKIT_AGENT"; then
    fail "agent '$PIPEKIT_AGENT' is not available — check.sh failed (missing CLI or credentials)"
  fi
  PICK="$PIPEKIT_AGENT"
else
  log "agent (preferred): $PREFERRED"
  IFS=',' read -ra CANDIDATES <<< "$PREFERRED"
  for candidate in "${CANDIDATES[@]}"; do
    candidate="$(echo "$candidate" | xargs)"
    [[ -z "$candidate" ]] && continue
    if agent_check "$candidate"; then
      PICK="$candidate"
      log "agent picked: $PICK"
      break
    else
      log "agent skipped: $candidate (unavailable)"
    fi
  done
  [[ -n "$PICK" ]] \
    || fail "no preferred agent available — set credentials for one of: $PREFERRED"
fi

DRIVER="$DRIVERS_DIR/$PICK/run.sh"
[[ -x "$DRIVER" ]] || fail "driver not executable: $DRIVER"

# ─── Hand off to driver ────────────────────────────────────────────────────
export PIPEKIT_WORKSPACE="$WORKSPACE"
export PIPEKIT_AGENT="$PICK"

cd "$WORKSPACE"
set +e
"$DRIVER" "$PROMPT_PATH"
DRIVER_EXIT=$?
set -e

# ─── Validate output ───────────────────────────────────────────────────────
if [[ $DRIVER_EXIT -ne 0 ]]; then
  log "driver $PICK exited non-zero ($DRIVER_EXIT)"
  if [[ ! -f "$WORKSPACE/result.json" ]]; then
    printf '{"status":"fail","summary":"driver %s exited %d without writing result.json"}' \
      "$PICK" "$DRIVER_EXIT" > "$WORKSPACE/result.json"
  fi
  exit 2
fi

if [[ ! -f "$WORKSPACE/result.json" ]]; then
  log "ERROR: agent did not write result.json"
  echo '{"status":"fail","summary":"agent did not write result.json"}' > "$WORKSPACE/result.json"
  exit 2
fi

jq empty "$WORKSPACE/result.json" 2>/dev/null \
  || fail "result.json is not valid JSON"

# ─── Compute verdict ───────────────────────────────────────────────────────
if [[ -n "${PIPEKIT_PASS_WHEN:-}" ]]; then
  log "evaluating pass-when: $PIPEKIT_PASS_WHEN"
  if jq -e "$PIPEKIT_PASS_WHEN" "$WORKSPACE/result.json" >/dev/null 2>&1; then
    log "verdict: pass (pass-when truthy)"
    exit 0
  else
    log "verdict: fail (pass-when falsy)"
    exit 1
  fi
fi

STATUS=$(jq -r '.status // "fail"' "$WORKSPACE/result.json")
log "verdict: $STATUS (from result.json:.status)"
[[ "$STATUS" == "pass" ]] && exit 0 || exit 1
